{
    "version": "0.3.0",
    "description": "Zotero/Jurism-Plugin zur Bestandsabfrage im Swisscovery UB Bern",

    "config": {
    "addonName": "Swisscovery UB Bern Locations",
    "addonID": "zoteroswisscoveryubbernlocations@ubbe.org",
    "addonRef": "zoteroswisscoveryubbernlocations",
    "addonInstance": "ZoteroSwisscoveryUbbernLocations",
    "prefsPrefix": "extensions.zotero.swisscoveryubbernlocations"
    },

    "author": "Denis Maier",

    "repository": {
    "type": "git",
    "url": "git+https://github.com/ub-unibe-ch/zotero-swissbib-bb-locations.git"
    },

     "bugs": {
        "url": "https://github.com/ub-unibe-ch/zotero-swissbib-bb-locations/issues"
    },
    "homepage": "https://github.com/ub-unibe-ch/zotero-swissbib-bb-locations",
    
    "scripts": {
        "start": "zotero-plugin serve",
        "build": "zotero-plugin build",
        "release": "zotero-plugin release",
        "bump": "bumpp --commit \"chore(publish): release v%s\" --no-tag",
        "make-release": "node scripts/make-release.mjs",
        "make-release:force": "node scripts/make-release.mjs --force",
        "make-release:dry": "node scripts/make-release.mjs --dry-run",
        "publish": "node scripts/publish.mjs",
        "test": "jest"
    },
    "jest": {
        "testMatch": [
            "**/tests/**/*.test.js"
        ]
    },
    "dependencies": {
        "jsdom": "^24.1.0"
    },
    "devDependencies": {
        "bumpp": "^10.4.1",
        "jest": "^30.2.0",
        "zotero-plugin-scaffold": "^0.8.3"
    }
}