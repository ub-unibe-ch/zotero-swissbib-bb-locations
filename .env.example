# Zotero executable path (adjust for your OS)
ZOTERO_PLUGIN_ZOTERO_BIN_PATH="C:/Program Files/Zotero/zotero.exe"

# Zotero profile path for plugin development
# Create a separate profile for development: Zotero -> Profile Manager
ZOTERO_PLUGIN_PROFILE_PATH="C:/Users/YOUR_USERNAME/AppData/Roaming/Zotero/Zotero/Profiles/YOUR_PROFILE_DIR"

# Optional: Zotero Beta (used by `pnpm run startbeta`)
# Install Zotero Beta to a separate location and create a separate profile for it
ZOTERO_PLUGIN_ZOTERO_BIN_PATH_BETA="C:/Program Files/Zotero Beta/zotero.exe"
ZOTERO_PLUGIN_PROFILE_PATH_BETA="C:/Users/YOUR_USERNAME/AppData/Roaming/Zotero/Zotero/Profiles/YOUR_BETA_PROFILE_DIR"
